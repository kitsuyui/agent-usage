{
  "name": "agent-usage",
  "version": "0.1.0",
  "description": "Track AI coding agent rate limits and usage over time, with HTTP/MCP APIs and a small dashboard.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "agent-usage": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts daemon",
    "sample": "bun run src/cli/index.ts sample",
    "build:frontend": "bun run scripts/build-frontend.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "typecheck": "tsc --noEmit && tsc --noEmit -p frontend/tsconfig.json",
    "lint": "eslint .",
    "test": "bun test",
    "prepare": "bun run db:generate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@prisma/client": "^6.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "eslint": "^9.17.0",
    "prisma": "^6.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.14"
}
