DATABASE_URL="file:../data/agent-usage.db"
HTTP_PORT=7979
SAMPLE_INTERVAL_SECONDS=900

# Set on the server to require this bearer token on POST /api/usage/samples.
# Omit for an unauthenticated ingest endpoint (fine on a trusted network —
# put a proper auth layer, e.g. a reverse proxy or VPN, in front otherwise).
# INGEST_TOKEN=

# Set on a standalone collector to push captured snapshots to a central
# server instead of writing to a local database. Leave unset for the
# all-in-one deployment (local database + HTTP API + sampler, all in one
# process — this is the default).
# INGEST_SERVER_URL=http://collector-host:7979
